# =====================================================
# Secure File Transfer System - Environment Configuration
# Week 5: Environment Hardening
# =====================================================
# Copy this file to .env and configure for your environment
# NEVER commit .env to version control

# =====================================================
# FLASK APPLICATION SETTINGS
# =====================================================
# Secret key for session management (use a strong random value in production)
FLASK_SECRET_KEY=your-secure-random-secret-key-here-change-in-production

# Flask environment (development or production)
FLASK_ENV=development

# Debug mode (set to False in production)
DEBUG=True

# Host and port for Flask application
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# =====================================================
# FILE UPLOAD SETTINGS
# =====================================================
# Maximum file upload size in MB
MAX_FILE_SIZE_MB=50

# Upload folder location (relative to app root)
UPLOAD_FOLDER=app/uploads
PLAIN_UPLOAD_FOLDER=app/uploads/plain_uploads
ENCRYPTED_UPLOAD_FOLDER=app/uploads/encrypted_uploads

# =====================================================
# LOGGING SETTINGS
# =====================================================
# Log folder location
LOG_FOLDER=logs

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=DEBUG

# =====================================================
# SECURITY SETTINGS
# =====================================================
# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=30

# Maximum login attempts before temporary lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout duration in minutes
LOCKOUT_DURATION_MINUTES=15

# =====================================================
# ENCRYPTION SETTINGS
# =====================================================
# Algorithm (currently using Fernet/AES-256)
ENCRYPTION_ALGORITHM=Fernet

# Key rotation policy (none, periodic, on-access)
KEY_ROTATION_POLICY=none

# =====================================================
# DATABASE SETTINGS
# =====================================================
# Storage mode
STORAGE_MODE=database

# PostgreSQL database URL
DATABASE_URL=postgresql://superAdmin:super%40admin@localhost:5432/models_db

# =====================================================
# EXPERIMENT/RESEARCH SETTINGS
# =====================================================
# Enable metrics collection for research
METRICS_ENABLED=True

# Store raw metrics in separate file
METRICS_OUTPUT_FILE=logs/metrics.json
